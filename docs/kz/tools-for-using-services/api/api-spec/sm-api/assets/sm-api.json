        "schema": {
          "type": "string"
        }
      },
      "List": {
        "name": "list",
        "in": "query",
        "description": "list операциясына сұрау, бұл сұрау үшін LIST әдісін пайдалануға болады",
        "schema": {
          "type": "boolean"
        }
      },
      "Scan": {
        "name": "scan",
        "in": "query",
        "description": "scan операциясына сұрау, бұл сұрау үшін SCAN әдісін пайдалануға болады",
        "schema": {
          "type": "boolean"
        }
      },
      "Version": {
        "name": "version",
        "in": "query",
