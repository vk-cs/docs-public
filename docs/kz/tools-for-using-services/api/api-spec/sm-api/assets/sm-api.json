            "x-omitzero": false
          },
          "created_time": {
            "type": "string",
            "format": "date-time",
            "x-omitempty": false,
            "x-omitzero": false
          },
          "deletion_time": {
            "type": "string",
            "format": "date-time",
            "x-omitempty": false,
            "x-omitzero": false
          },
          "destroyed": {
            "type": "boolean",
            "x-omitempty": false,
            "x-omitzero": false
          },
          "custom_metadata": {
            "type": "object",
            "additionalProperties": true,
            "x-omitempty": false,
            "x-omitzero": false
